function core.facingTarget()
	--Make sure we're facing the target
	local currentLookVector = myRoot.CFrame.LookVector
	local targetPos = status:get("currentTarget").Position
	local goalLookVector = CFrame.new(myRoot.Position,Vector3.new(
		targetPos.X,
		myRoot.Position.Y,
		targetPos.Z
		)).LookVector
	local difference = (currentLookVector - goalLookVector).Magnitude
	if difference < 0.5 then
		return true
	else
		return false
	end
end
