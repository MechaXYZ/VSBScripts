function pushBullet(bullet)
	--Testing removing marine from ignore list
	--Magic fastcast
	local speed = 7
	local iterations = 20
	
	local params = RaycastParams.new()
	params.FilterDescendantsInstances = {workspace.Terrain}
	
	runService.Heartbeat:Wait() --Give bullet time to render from barrel
	bullet.CFrame = m4.CFrame * CFrame.new(0,0.2,-2.5)
	runService.Heartbeat:Wait() --Give bullet time to render from barrel
	
	core.spawn(function()
		while true do
			local position,nextPosition = bullet.Position,Vector3.new(0,0,speed)
	        local result = workspace:Raycast(position, bullet.CFrame.LookVector*speed,params)
			if result and result.Instance.Name ~= "Bullet" then	
				bullet.CFrame = CFrame.new(result.Position)
				removeBullet(bullet)
				
				--local human = result.Instance.Parent:FindFirstChildWhichIsA("Humanoid")
				local human = core.getHuman(result.Instance.Parent)
				impact.WorldPosition = result.Position
				if human and human.Health > 0 then
					--human:TakeDamage(math.random(5,15))
					core.applyDamage(human,math.random(5,15))
					--impact.Hit:Play()
					if human.Health <= 0 then
						targeting.findTarget()
					end
				elseif not human then
					--impact.Miss:Play()
					impact.Debris:Emit(1)
					for i = 1, math.random(2,3) do
						local chunk = Instance.new("SpawnLocation")
						chunk.Enabled = false
						chunk.Color = result.Instance.Color
						chunk.Material = result.Instance.Material
						local size = math.random(5)/20
						chunk.Size = Vector3.new(size,size,size)
						chunk.CFrame = CFrame.new(result.Position)
						chunk.Anchored = false
						chunk.Velocity = Vector3.new(math.random(-20,20),math.random(10,20),math.random(-20,20))
						chunk.Parent = workspace
						debrisService:AddItem(chunk,1)
					end
				end
				break
	        else
				bullet.CFrame = bullet.CFrame * CFrame.new(-nextPosition)
			end
			
			iterations -= 1
			if iterations < 0 then
				bullet:Destroy()
				break
			end
			game:GetService("RunService").Heartbeat:Wait()
		end
	end)
end

local flashIndex = 1
function combat.shoot(target)
	if status:get("weaponCool") and not status:get("reloading") then
		status:set("weaponCool",false)
		
		local shot
		if core.checkDist(target,myRoot) > 60 then
			shot = 1
		else
			shot = 3
		end
		for i = 1, shot do
			task.wait(0.1)
			status:set("mag",status:get("mag")-1)
			
			--flash:Emit(1)
			core.spawn(function() 
				barrel.FlashBG["Flash"..flashIndex].Visible = true
				lightFlash.Enabled = true 
				task.wait(0.1) 
				lightFlash.Enabled = false 
				barrel.FlashBG["Flash"..flashIndex].Visible = false
				flashIndex = flashIndex + 1
				if flashIndex > 3 then
					flashIndex = 1
				end
			end)
			
			--bullet.CFrame = m4.CFrame * CFrame.new(0,0.2,-2.5) --z: 0.5
			pushBullet(combat.getBullet())
			
			local case = combat.getCase()
			case.CFrame = chamber.WorldCFrame
			case.Velocity = case.CFrame.RightVector * -20 * Vector3.new(1,-3,1)
			core.spawn(function() 
				wait(0.05) 
				case.CanCollide = true 
				task.wait(2)
				case:Destroy()
			end)

			fireSound:Play()

			--Kick
			local original = m4.HingeAttach1.Position
			m4.HingeAttach1.Position = original - Vector3.new(0,0,0.2)
			tweenService:Create(m4.HingeAttach1, TweenInfo.new(0.1),{Position = original}):Play()
			
		end
		
		if status:get("mag") <= 0 then
			actions.reload()
		end

		--New thread here before
		task.wait(mySettings.M4.Delay)
		status:set("weaponCool",true)
	end
end

