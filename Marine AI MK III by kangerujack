local targeting = {}
local myRoot = marine.HumanoidRootPart
function targeting.findTarget()
	local dist = mySettings.DetectionRange
	local target = nil
	status:set("potentialTargets",{})
	status:set("activeAllies",{})
	local seeTargets = {}
	for _,v in ipairs(workspace:GetChildren()) do
		local human = v:FindFirstChild("Humanoid")
		local torso = v:FindFirstChild("HumanoidRootPart") or v:FindFirstChild("Torso")
		if human and torso and v ~= marine then
			if (myRoot.Position - torso.Position).magnitude < dist and human.Health > 0 then
				local teammate = core.isAlly(v)
				if teammate then
					table.insert(status:get("activeAllies"),torso)
				else
					table.insert(status:get("potentialTargets"),torso)
				end
			end
		end
	end
	if #status:get("potentialTargets") > 0 then
		for i,v in ipairs(status:get("potentialTargets")) do
			if core.checkSight(v) then
				table.insert(seeTargets,v)
			end
		end
		if #seeTargets > 0 then
			for i,v in ipairs(seeTargets) do
				if (myRoot.Position - v.Position).magnitude < dist then
					target = v
					dist = (myRoot.Position - v.Position).magnitude
				end
			end
		else
			for i,v in ipairs(status:get("potentialTargets")) do
				if (myRoot.Position - v.Position).magnitude < dist then
					target = v
					dist = (myRoot.Position - v.Position).magnitude
				end
			end
		end
	end
	status:set("currentTarget",target)
end
