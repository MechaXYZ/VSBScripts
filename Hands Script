BendFingers("Right", RHAngle, RPLJ)
elseif k == rightkeys[2] then
BendFingers("Right", RHAngle, RRMJ)
elseif k == rightkeys[3] then
BendFingers("Right", RHAngle, RMMJ)
elseif k == rightkeys[4] then
BendFingers("Right", RHAngle, RPMJ)
