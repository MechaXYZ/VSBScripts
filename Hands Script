local RightMotors = {}
local LeftMotors = {}


for i,x in pairs(RH:GetDescendants()) do
	if x:IsA("Motor6D") then
		table.insert(RightMotors,{x,x.C1})
	end
end
for i,x in pairs(LH:GetDescendants()) do
	if x:IsA("Motor6D") then
		table.insert(LeftMotors,{x,x.C1})
	end
end

local function BendFingers(Hand, Rot, Joint)
	local joints = (Hand == "Right" and RightMotors) or (Hand == "Left" and LeftMotors)
	local Rot = (Hand == "Right" and -Rot) or (Hand == "Left" and Rot)
	for _, x in pairs(joints) do
		if x[1] == Joint and Joint.Name == "ThumbJoint" then
			game:GetService("TweenService"):Create(x[1], TweenInfo.new(.5), {C1 = x[2] * CFrame.Angles(math.rad(45*Rot),math.rad(10*Rot),0)}):Play()
		elseif x[1] == Joint and Joint.Name ~= "ThumbJoint" then
			game:GetService("TweenService"):Create(x[1], TweenInfo.new(.5), {C1 = x[2] * CFrame.Angles(math.rad(25*Rot),0,0)}):Play()
		end
	end
end
local RHAngle = 2.25
local RPLJ = RH:FindFirstChild("PinkyLowerJoint", true)
